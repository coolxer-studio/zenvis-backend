{
	"type": "page",
	"title": "插件管理",
	"remark": null,
	"toolbar": [
		{
			"type": "button",
			"actionType": "dialog",
			"label": "创建插件",
			"primary": true,
			"dialog": {
				"title": "创建插件",
				"mode": "horizontal",
				"size": "lg",
				"body": {
					"type": "form",
					"api": "/zenvis/api/v1/system/plugin/add",
					"body": [
						{
							"type": "input-file",
							"name": "file",
							"label": "上传插件包",
							"accept": ".tar.gz",
							"drag": true,
							"receiver": "/zenvis/api/v1/system/plugin/upload",
							"autoFill": {
								"name": "${name}",
								"package_name": "${package_name}",
								"version": "${version}",
								"description": "${description}",
								"author": "${author}",
								"plugin_path": "${plugin_path}",
								"icon": "${icon}"
							}
						},
						{
							"type": "input-image",
							"name": "icon",
							"label": "插件图标(可选)",
							"receiver": "/zenvis/api/v1/system/plugin/icon/base64"
						},
						{
							"label": "插件名称",
							"name": "name",
							"type": "input-text",
							"required": true
						},
						{
							"label": "包名",
							"name": "package_name",
							"type": "input-text",
							"required": true
						},
						{
							"label": "版本",
							"name": "version",
							"type": "input-text",
							"required": true
						},
						{
							"label": "描述",
							"name": "description",
							"type": "input-text",
							"required": true
						},
						{
							"label": "作者",
							"name": "author",
							"type": "input-text",
							"required": true
						},
						{
							"label": "插件路径",
							"name": "plugin_path",
							"type": "input-text",
							"placeholder": "系统分配插件路径",
							"disabled": true
						}
					]
				}
			}
		}
	],
	"body": [
		{
			"name": "plugin_list",
			"type": "crud",
			"api": "/zenvis/api/v1/system/plugin/list",
			"mode": "cards",
			"columnsCount": 4,
			"defaultParams": {
				"perPage": 12
			},
			"filter": {
				"title": "搜索",
				"body": [
					{
						"label": "插件名称",
						"type": "input-text",
						"name": "name",
						"clearable": true,
						"placeholder": "通过插件名称搜索",
						"size": "lg"
					},
					{
						"label": "插件包名",
						"type": "input-text",
						"name": "package_name",
						"clearable": true,
						"placeholder": "通过插件包名搜索",
						"size": "lg"
					}
				],
				"actions": [
					{
						"type": "reset",
						"label": "重置"
					},
					{
						"type": "submit",
						"level": "primary",
						"label": "查询"
					}
				]
			},
			"card": {
				"header": {
					"title": "$name",
					"subTitle": "${description | truncate:24}",
					"subTitlePlaceholder": "暂无说明",
					"avatar": "${icon}",
					"avatarClassName": "pull-left b-3x m-r w-12 h-12"
				},
				"body": [
					{
						"name": "status",
						"label": "状态",
						"type": "mapping",
						"map": {
							"UN_INSTALL": "<span class='label label-info'>未安装</span>",
							"INSTALLED": "<span class='label label-danger'>已安装</span>",
							"*": "<span class='label label-default'>未知</span>"
						}
					},
					{
						"name": "package_name",
						"label": "包名",
						"type": "tpl",
						"tpl": "${package_name|truncate:24}",
						"popOver": {
							"trigger": "hover",
							"position": "left-top",
							"showIcon": false,
							"body": {
								"type": "tpl",
								"tpl": "${package_name}"
							}
						}
					},
					{
						"name": "version",
						"label": "版本",
						"type": "text"
					},
					{
						"name": "author",
						"label": "作者",
						"type": "text"
					},
					{
						"name": "plugin_path",
						"label": "安装路径",
						"type": "tpl",
						"tpl": "${plugin_path|truncate:24}",
						"popOver": {
							"trigger": "hover",
							"position": "left-top",
							"showIcon": false,
							"body": {
								"type": "tpl",
								"tpl": "${plugin_path}"
							}
						}
					},
					{
						"name": "update_time",
						"label": "更新时间"
					}
				],
				"actionsCount": 4,
				"actions": [
					{
						"type": "button",
						"label": "查看",
						"actionType": "dialog",
						"icon": "fa fa-eye text-info",
						"dialog": {
							"title": "插件说明文档",
							"size": "full",
							"body": {
								"type": "service",
								"api": "/zenvis/api/v1/system/plugin/${id}/readme",
								"body": [
									{
										"type": "markdown",
										"hiddenOn": "data.status == 'INSTALLED'",
										"value": "${value | url_decode}"
									},
									{
										"type": "grid",
										"hiddenOn": "data.status != 'INSTALLED'",
										"columns": [
											{
												"md": 0,
												"body": [
													{
														"type": "input-tree",
														"name": "doc_name",
														"heightAuto": true,
														"onlyLeaf": true,
														"source": "/zenvis/api/v1/system/plugin/${id}/doc/tree"
													}
												]
											},
											{
												"md": 9,
												"body": [
													{
														"type": "wrapper",
														"body": {
															"type": "service",
															"api": "/zenvis/api/v1/system/plugin/${id}/doc/view?file=${doc_name}",
															"body": {
																"type": "markdown",
																"value": "${value | url_decode}"
															}
														},
														"size": "md",
														"className": "b"
													}
												]
											}
										]
									}
								]
							}
						}
					},
					{
						"type": "button",
						"label": "安装",
						"icon": "fa fa-play text-success",
						"hiddenOn": "data.status == 'INSTALLED'",
						"actionType": "dialog",
						"dialog": {
							"id": "dialog_install",
							"data": {
								"plugin_id": "${id}",
								"hide_log": true,
								"hide_confirm": false
							},
							"title": "请确认是否安装？",
							"actions": [
								{
									"label": "取消",
									"actionType": "cancel",
									"type": "button",
									"hiddenOn": "data.hide_confirm"
								},
								{
									"type": "button",
									"actionType": "reload",
									"target": "plugin_list",
									"label": "完成",
									"hiddenOn": "!data.hide_confirm",
									"primary": true,
									"close": true
								},
								{
									"label": "安装",
									"primary": true,
									"type": "button",
									"hiddenOn": "data.hide_confirm",
									"onEvent": {
										"click": {
											"actions": [
												{
													"actionType": "ajax",
													"api": "post:/zenvis/api/v1/system/plugin/${plugin_id}/install"
												},
												{
													"actionType": "setValue",
													"componentId": "dialog_install",
													"args": {
														"value": {
															"hide_log": false,
															"hide_confirm": true
														}
													}
												}
											]
										}
									}
								}
							],
							"body": [
								{
									"type": "log",
									"height": 300,
									"hiddenOn": "data.hide_log",
									"source": "/zenvis/api/v1/system/plugin/${plugin_id}/logs"
								}
							]
						}
					},
					{
						"type": "button",
						"label": "卸载",
						"icon": "fa fa-stop text-warning",
						"hiddenOn": "data.status != 'INSTALLED'",
						"actionType": "dialog",
						"dialog": {
							"id": "dialog_uninstall",
							"data": {
								"plugin_id": "${id}",
								"hide_log": true,
								"hide_confirm": false
							},
							"title": "请确认是否卸载？",
							"actions": [
								{
									"label": "取消",
									"actionType": "cancel",
									"type": "button",
									"hiddenOn": "data.hide_confirm"
								},
								{
									"type": "button",
									"actionType": "reload",
									"target": "plugin_list",
									"label": "完成",
									"hiddenOn": "!data.hide_confirm",
									"primary": true,
									"close": true
								},
								{
									"label": "卸载",
									"primary": true,
									"type": "button",
									"hiddenOn": "data.hide_confirm",
									"onEvent": {
										"click": {
											"actions": [
												{
													"actionType": "ajax",
													"api": "post:/zenvis/api/v1/system/plugin/${plugin_id}/uninstall"
												},
												{
													"actionType": "setValue",
													"componentId": "dialog_uninstall",
													"args": {
														"value": {
															"hide_log": false,
															"hide_confirm": true
														}
													}
												}
											]
										}
									}
								}
							],
							"body": [
								{
									"type": "log",
									"height": 300,
									"hiddenOn": "data.hide_log",
									"source": "/zenvis/api/v1/system/plugin/${plugin_id}/logs"
								}
							]
						}
					},
					{
						"type": "button",
						"label": "更新",
						"icon": "fa fa-pencil text-warning",
						"actionType": "dialog",
						"disabledOn": "data.status == 'INSTALLED'",
						"dialog": {
							"title": "更新",
							"size": "lg",
							"body": {
								"type": "form",
								"name": "sample-edit-form",
								"api": "/zenvis/api/v1/system/plugin/${id}/update",
								"body": [
									{
										"type": "input-file",
										"name": "file",
										"label": "上传插件包",
										"accept": ".tar.gz",
										"drag": true,
										"receiver": "/zenvis/api/v1/system/plugin/upload",
										"autoFill": {
											"name": "${name}",
											"package_name": "${package_name}",
											"version": "${version}",
											"description": "${description}",
											"author": "${author}",
											"plugin_path": "${plugin_path}",
											"icon": "${icon}"
										}
									},
									{
										"type": "input-image",
										"name": "icon",
										"label": "插件图标(可选)",
										"receiver": "/zenvis/api/v1/system/plugin/icon/base64"
									},
									{
										"label": "插件名称",
										"name": "name",
										"type": "input-text",
										"required": true
									},
									{
										"label": "包名",
										"name": "package_name",
										"type": "input-text",
										"required": true
									},
									{
										"label": "版本",
										"name": "version",
										"type": "input-text",
										"required": true
									},
									{
										"label": "描述",
										"name": "description",
										"type": "input-text",
										"required": true
									},
									{
										"label": "作者",
										"name": "author",
										"type": "input-text",
										"required": true
									},
									{
										"label": "插件路径",
										"name": "plugin_path",
										"type": "input-text",
										"placeholder": "系统分配插件路径",
										"disabled": true
									}
								]
							}
						}
					},
					{
						"type": "button",
						"label": "删除",
						"icon": "fa fa-trash text-danger",
						"actionType": "ajax",
						"confirmText": "您确认要删除?",
						"disabledOn": "data.status == 'INSTALLED'",
						"api": "delete:/zenvis/api/v1/system/plugin/$id"
					},
					{
						"type": "button",
						"label": "下载",
						"icon": "fa fa-download text-primary",
						"actionType": "download",
						"api": "/zenvis/api/v1/system/plugin/$id/export"
					}
				]
			}
		}
	]
}