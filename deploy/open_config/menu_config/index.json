{
  "type": "page",
  "title": "菜单管理",
  "remark": null,
  "toolbar": [
    {
      "type": "button",
      "actionType": "dialog",
      "label": "创建菜单",
      "primary": true,
      "dialog": {
        "title": "创建菜单",
        "mode": "horizontal",
        "body": {
          "type": "form",
          "api": "/zenvis/api/v1/system/menu/add",
          "body": [
            {
              "label": "名称",
              "name": "name",
              "type": "input-text",
              "required": true
            },
            {
              "label": "菜单级别",
              "name": "level",
              "type": "radios",
              "required": true,
              "source": "/zenvis/api/v1/system/menu/level/list"
            },
            {
              "label": "父菜单",
              "name": "parent_id",
              "type": "select",
              "required": true,
              "source": "/zenvis/api/v1/system/menu/parent-menu/list",
              "hiddenOn": "data.level != 'LEVEL_2'"
            },
            {
              "label": "菜单类型",
              "name": "type",
              "type": "select",
              "required": true,
              "source": "/zenvis/api/v1/system/menu/type/list"
            },
            {
              "label": "路由",
              "name": "route",
              "type": "input-text",
              "required": true,
              "hiddenOn": "data.type != 'BUILT_APP'"
            },
            {
              "label": "参数",
              "name": "params",
              "type": "input-text"
            },
            {
              "type": "checkbox",
              "name": "create_root_path",
              "label": "创建根路径",
              "option": "",
              "hiddenOn": "data.type != 'POLICY_CONFIG'"
            },
            {
              "type": "input-text",
              "label": "角标文字",
              "name": "superscript",
              "description": "<span class=\"text-info\">可选，用于突出菜单</span>"
            }
          ]
        }
      }
    }
  ],
  "body": [
    {
      "type": "crud",
      "api": "/zenvis/api/v1/system/menu/list",
      "saveOrderApi": "/zenvis/api/v1/system/menu/update-order",
      "draggable": true,
      "autoGenerateFilter": true,
      "columns": [
        {
          "name": "id",
          "label": "ID",
          "type": "text",
          "toggled": true
        },
        {
          "name": "name",
          "label": "菜单名称",
          "type": "text",
          "searchable": true,
          "toggled": true
        },
        {
          "name": "type_description",
          "label": "菜单类型",
          "type": "mapping",
          "map": {
            "内置应用": "<span class='label label-info'>${type_description}</span>",
            "外联应用": "<span class='label label-success'>${type_description}</span>",
            "低代码应用": "<span class='label label-danger'>${type_description}</span>",
            "低代码页面": "<span class='label label-danger'>${type_description}</span>",
            "策略配置": "<span class='label label-warning'>${type_description}</span>",
            "*": "<span class='label label-default'>${type_description}</span>"
          },
          "toggled": true
        },
        {
          "name": "route",
          "label": "路由",
          "type": "text",
          "searchable": true,
          "toggled": true
        },
        {
          "name": "params",
          "label": "参数",
          "type": "text",
          "toggled": true
        },
        {
          "name": "superscript",
          "label": "角标",
          "type": "text",
          "toggled": true
        },
        {
          "name": "update_time",
          "label": "更新时间",
          "type": "text",
          "toggled": true
        },
        {
          "type": "operation",
          "label": "操作",
          "width": 100,
          "buttons": [
            {
              "type": "button",
              "disabledOn": "${!is_editable}",
              "icon": "fa fa-pencil",
              "actionType": "dialog",
              "dialog": {
                "size": "lg",
                "title": "编辑",
                "body": {
                  "type": "form",
                  "name": "sample-edit-form",
                  "api": "/zenvis/api/v1/system/menu/$id/update",
                  "body": [
                    {
                      "label": "名称",
                      "name": "name",
                      "type": "input-text",
                      "required": true
                    },
                    {
                      "label": "菜单级别",
                      "name": "level",
                      "type": "radios",
                      "required": true,
                      "source": "/zenvis/api/v1/system/menu/level/list"
                    },
                    {
                      "label": "父菜单",
                      "name": "parent_id",
                      "type": "select",
                      "required": true,
                      "source": "/zenvis/api/v1/system/menu/parent-menu/list",
                      "hiddenOn": "data.level != 'LEVEL_2'"
                    },
                    {
                      "label": "菜单类型",
                      "name": "type",
                      "type": "select",
                      "required": true,
                      "source": "/zenvis/api/v1/system/menu/type/list"
                    },
                    {
                      "label": "路由",
                      "name": "route",
                      "type": "input-text",
                      "required": true,
                      "hiddenOn": "data.type != 'BUILT_APP'"
                    },
                    {
                      "label": "参数",
                      "name": "params",
                      "type": "input-text"
                    },
                    {
                      "type": "input-text",
                      "label": "角标文字",
                      "name": "superscript",
                      "description": "<span class=\"text-info\">可选，用于突出菜单</span>"
                    }
                  ]
                }
              }
            },
            {
              "type": "button",
              "disabledOn": "${!is_editable}",
              "icon": "fa fa-times text-danger",
              "actionType": "ajax",
              "confirmText": "您确认要删除?",
              "api": "delete:/zenvis/api/v1/system/menu/$id"
            }
          ],
          "toggled": true
        }
      ]
    }
  ]
}