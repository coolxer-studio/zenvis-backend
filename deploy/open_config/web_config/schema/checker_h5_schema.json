        "screen": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cpu": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "battery": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "uuid": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "network": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "storage": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "browser": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
