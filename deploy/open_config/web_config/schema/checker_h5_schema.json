          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "document": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "window": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "navigator": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
