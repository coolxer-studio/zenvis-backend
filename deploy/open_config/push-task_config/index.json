{
  "type": "page",
  "title": "数推服务管理",
  "remark": null,
  "toolbar": [
    {
      "type": "button",
      "actionType": "dialog",
      "label": "创建数推服务",
      "primary": true,
      "dialog": {
        "title": "创建数推任务",
        "mode": "horizontal",
        "size": "lg",
        "body": {
          "type": "form",
          "api": "/zenvis/api/v1/system/push-task/add",
          "body": [
            {
              "label": "数推服务名称",
              "name": "name",
              "type": "input-text",
              "required": true
            },
            {
              "label": "描述说明",
              "type": "textarea",
              "name": "description",
              "required": true,
              "clearable": true
            },
            {
              "label": "推送配置",
              "name": "config",
              "type": "editor",
              "language": "yaml",
              "editorTheme": "vs-dark",
              "required": true
            },
            {
              "type": "hidden",
              "name": "source",
              "value": "WEB"
            }
          ]
        }
      }
    }
  ],
  "body": [
    {
      "type": "crud",
      "api": "/zenvis/api/v1/system/push-task/all",
      "loadDataOnce": true,
      "autoGenerateFilter": true,
      "columns": [
        {
          "name": "id",
          "label": "ID",
          "type": "text",
          "toggled": true
        },
        {
          "name": "name",
          "label": "数推服务名称",
          "type": "text",
          "searchable": true,
          "toggled": true
        },
        {
          "name": "description",
          "label": "描述",
          "type": "text",
          "searchable": true,
          "toggled": true
        },
        {
          "type": "tpl",
          "tpl": "${config | json |truncate:60}",
          "name": "config",
          "label": "配置",
          "toggled": true,
          "popOver": {
            "body": {
              "type": "code",
              "language": "yaml",
              "maxHeight": 400,
              "editorTheme": "vs-dark",
              "value": "${config}"
            }
          }
        },
        {
          "name": "status",
          "label": "状态",
          "type": "status",
          "source": {
            "running": {
              "label": "运行中",
              "icon": "rolling"
            },
            "running[error]": {
              "label": "不稳定运行中",
              "icon": "rolling"
            },
            "stopped": {
              "label": "未运行",
              "icon": "warning"
            },
            "error": {
              "label": "异常",
              "icon": "fail"
            }
          },
          "toggled": true
        },
        {
          "name": "pid",
          "label": "进程id",
          "type": "text",
          "searchable": true,
          "toggled": true
        },
        {
          "name": "source",
          "label": "来源",
          "type": "text",
          "searchable": true,
          "toggled": true
        },
        {
          "name": "mark",
          "label": "备注",
          "type": "text",
          "searchable": true,
          "toggled": true
        },
        {
          "name": "update_time",
          "label": "更新时间",
          "type": "text",
          "toggled": true
        },
        {
          "name": "create_time",
          "label": "创建时间",
          "type": "text",
          "toggled": true
        },
        {
          "type": "operation",
          "label": "操作",
          "width": 200,
          "buttons": [
            {
              "type": "button",
              "icon": "fa fa-pause-circle text-danger",
              "hiddenOn": "status == 'stopped'",
              "actionType": "ajax",
              "confirmText": "您确认要停止?",
              "api": "post:/zenvis/api/v1/system/push-task/$id/toggle"
            },
            {
              "type": "button",
              "icon": "fa fa-play-circle text-info",
              "hiddenOn": "status != 'stopped'",
              "actionType": "ajax",
              "confirmText": "您确认要启动?",
              "api": "post:/zenvis/api/v1/system/push-task/$id/toggle"
            },
            {
              "type": "button",
              "icon": "fa fa-pencil",
              "actionType": "dialog",
              "dialog": {
                "size": "lg",
                "title": "编辑",
                "body": {
                  "type": "form",
                  "name": "sample-edit-form",
                  "api": "PUT:/zenvis/api/v1/system/push-task/$id",
                  "body": [
                    {
                      "label": "数推服务名称",
                      "name": "name",
                      "type": "input-text",
                      "required": true
                    },
                    {
                      "label": "描述说明",
                      "type": "textarea",
                      "name": "description",
                      "required": true,
                      "clearable": true
                    },
                    {
                      "label": "推送配置",
                      "name": "config",
                      "type": "editor",
                      "language": "yaml",
                      "editorTheme": "vs-dark",
                      "required": true
                    },
                    {
                      "type": "hidden",
                      "name": "source",
                      "value": "WEB"
                    }
                  ]
                }
              }
            },
            {
              "type": "button",
              "icon": "fa fa-sticky-note text-dark",
              "actionType": "dialog",
              "dialog": {
                "size": "full",
                "title": "查看日志",
                "body": {
                  "type": "tabs",
                  "tabsMode": "simple",
                  "tabs": [
                    {
                      "title": "控制台日志",
                      "body": [
                        {
                          "type": "log",
                          "operation": [
                            "showLineNumber",
                            "filter",
                            "restart"
                          ],
                          "source": "/zenvis/api/v1/system/push-task/$id/log?log_type=console"
                        }
                      ]
                    },
                    {
                      "title": "系统日志",
                      "body": [
                        {
                          "type": "log",
                          "operation": [
                            "showLineNumber",
                            "filter",
                            "restart"
                          ],
                          "source": "/zenvis/api/v1/system/push-task/$id/log?log_type=system"
                        }
                      ]
                    }
                  ]
                }
              }
            },
            {
              "type": "button",
              "icon": "fa fa-times text-danger",
              "actionType": "ajax",
              "confirmText": "您确认要删除?",
              "api": "delete:/zenvis/api/v1/system/push-task/$id"
            }
          ],
          "toggled": true
        }
      ]
    }
  ]
}